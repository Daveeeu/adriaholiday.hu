# Relative path — proxied to the backend by Vite's dev server (see vite.config.ts
# server.proxy) and by the production reverse proxy. Keep this relative so the
# browser always talks to the same origin as the SPA; pointing it at an absolute
# cross-origin URL (e.g. http://localhost:8000/api/admin) reintroduces CORS/
# credentials issues during local development.
VITE_API_BASE_URL=/api/admin
