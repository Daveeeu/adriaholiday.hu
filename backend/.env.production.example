APP_NAME="Adria Holiday"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://adriaholiday.hu

CORS_ALLOWED_ORIGINS=https://adriaholiday.hu

APP_LOCALE=hu
APP_FALLBACK_LOCALE=hu
APP_FAKER_LOCALE=hu_HU

LOG_CHANNEL=stack
LOG_STACK=stderr,daily
LOG_LEVEL=info
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=adriaholiday
DB_USERNAME=adriaholiday
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.adriaholiday.hu

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@adriaholiday.hu
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ANALYTICS_ENABLED=true
ANALYTICS_DEBUG=false
ANALYTICS_QUEUE=analytics
ANALYTICS_SESSION_COOKIE=ah_session_id
ANALYTICS_SESSION_LIFETIME=30
META_PIXEL_ID=
META_CAPI_ENABLED=false
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=
META_CAPI_API_VERSION=v20.0
META_CAPI_TIMEOUT=5

ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
